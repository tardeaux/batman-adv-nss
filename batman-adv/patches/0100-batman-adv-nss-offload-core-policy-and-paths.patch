+++ b/net/batman-adv/nss_rx.c	2026-03-05 18:37:58.449678145 -0600
@@ -0,0 +1,82 @@
+// SPDX-License-Identifier: GPL-2.0
+/* Copyright (C) B.A.T.M.A.N. contributors */
+
+#include "nss_internal.h"
+
+#include <linux/etherdevice.h>
+#include <linux/if_ether.h>
+
+#include "hard-interface.h"
+
+void batadv_nss_receive_from_nss(struct net_device *dev,
+				 struct sk_buff *skb,
+				 struct napi_struct *napi)
+{
+	struct batadv_hard_iface *hard_iface = NULL;
+	struct batadv_priv *bat_priv = NULL;
+	bool nss_user_ref = false;
+
+	if (!skb)
+		return;
+
+	if (unlikely(!dev))
+		goto drop;
+
+	hard_iface = batadv_hardif_get_by_netdev(dev);
+	if (!hard_iface)
+		goto drop;
+
+	if (unlikely(READ_ONCE(hard_iface->nssctx_teardown)))
+		goto drop;
+
+	atomic_inc(&hard_iface->nssctx_users);
+	nss_user_ref = true;
+	smp_mb__after_atomic();
+	if (unlikely(READ_ONCE(hard_iface->nssctx_teardown) ||
+		     !READ_ONCE(hard_iface->nssctx)))
+		goto drop;
+
+	if (unlikely(!hard_iface->mesh_iface))
+		goto drop;
+
+	bat_priv = netdev_priv(hard_iface->mesh_iface);
+	batadv_inc_counter(bat_priv, BATADV_CNT_NSS_RX_EXCEPTION);
+
+	if (unlikely(skb->mark & 0x80000000u)) {
+		batadv_inc_counter(bat_priv,
+				   BATADV_CNT_NSS_RX_EXCEPTION_DROP_MARK_ECHO);
+		goto drop;
+	}
+
+	if (likely(skb->len >= ETH_HLEN)) {
+		const struct ethhdr *eth = (const struct ethhdr *)skb->data;
+
+		if (unlikely(ether_addr_equal(eth->h_source, dev->dev_addr))) {
+			batadv_inc_counter(bat_priv,
+					   BATADV_CNT_NSS_RX_EXCEPTION_DROP_SRC_ECHO);
+			goto drop;
+		}
+	}
+
+	batadv_inc_counter(bat_priv, BATADV_CNT_NSS_RX_EXCEPTION_REINJECT);
+
+	skb->dev = dev;
+	skb->protocol = eth_type_trans(skb, dev);
+	if (napi)
+		napi_gro_receive(napi, skb);
+	else
+		netif_rx(skb);
+
+	if (nss_user_ref)
+		atomic_dec(&hard_iface->nssctx_users);
+	batadv_hardif_put(hard_iface);
+	return;
+
+drop:
+	if (bat_priv)
+		batadv_inc_counter(bat_priv, BATADV_CNT_NSS_RX_EXCEPTION_DROP);
+	kfree_skb(skb);
+	if (nss_user_ref)
+		atomic_dec(&hard_iface->nssctx_users);
+	batadv_hardif_put(hard_iface);
+}
--- /dev/null	2026-02-26 01:46:56.076000000 -0600
+++ b/net/batman-adv/nss_tx.c	2026-03-05 18:37:58.449678145 -0600
@@ -0,0 +1,281 @@
+// SPDX-License-Identifier: GPL-2.0
+/* Copyright (C) B.A.T.M.A.N. contributors */
+
+#include "nss.h"
+#include "nss_internal.h"
+
+#include <linux/if_ether.h>
+#include <linux/jiffies.h>
+
+#include <nss_api_if.h>
+
+#include "hard-interface.h"
+
+static void batadv_nss_wifi_control_nonuc_seen(struct batadv_priv *bat_priv, u8 packet_type)
+{
+	if (!bat_priv)
+		return;
+
+	batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_WIFI_SEEN_CONTROL_NONUC);
+
+	switch (packet_type) {
+	case BATADV_IV_OGM:
+		batadv_inc_counter(bat_priv,
+				   BATADV_CNT_NSS_TX_WIFI_SEEN_CONTROL_NONUC_IV_OGM);
+		break;
+	case BATADV_OGM2:
+		batadv_inc_counter(bat_priv,
+				   BATADV_CNT_NSS_TX_WIFI_SEEN_CONTROL_NONUC_OGM2);
+		break;
+	case BATADV_ELP:
+		batadv_inc_counter(bat_priv,
+				   BATADV_CNT_NSS_TX_WIFI_SEEN_CONTROL_NONUC_ELP);
+		break;
+	case BATADV_CODED:
+		batadv_inc_counter(bat_priv,
+				   BATADV_CNT_NSS_TX_WIFI_SEEN_CONTROL_NONUC_CODED);
+		break;
+	}
+}
+
+static inline struct nss_virt_if_handle *
+batadv_nss_ctx_get(struct batadv_hard_iface *hard_iface)
+{
+	struct nss_virt_if_handle *nssctx;
+
+	if (unlikely(READ_ONCE(hard_iface->nssctx_teardown)))
+		return NULL;
+
+	atomic_inc(&hard_iface->nssctx_users);
+	smp_mb__after_atomic();
+	nssctx = READ_ONCE(hard_iface->nssctx);
+	if (unlikely(!nssctx || READ_ONCE(hard_iface->nssctx_teardown))) {
+		atomic_dec(&hard_iface->nssctx_users);
+		return NULL;
+	}
+
+	return nssctx;
+}
+
+static inline void batadv_nss_ctx_put(struct batadv_hard_iface *hard_iface)
+{
+	atomic_dec(&hard_iface->nssctx_users);
+}
+
+bool batadv_nss_xmit(struct sk_buff *skb,
+		     struct batadv_hard_iface *hard_iface,
+		     const u8 *dst_addr, int *ret)
+{
+	struct batadv_priv *bat_priv = NULL;
+	struct batadv_nss_wifi_policy_result wifi_result;
+	struct nss_virt_if_handle *nssctx;
+	unsigned long now, retry_j;
+	bool nonlinear_copy;
+	struct sk_buff *nss_skb;
+	const bool is_wifi = batadv_is_wifi_hardif(hard_iface);
+	const bool direct_submit = batadv_nss_direct_submit_active();
+	nss_tx_status_t status;
+
+	if (likely(hard_iface->mesh_iface))
+		bat_priv = netdev_priv(hard_iface->mesh_iface);
+
+	if (unlikely(!batadv_nss_offload_enable)) {
+		if (bat_priv)
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_BYPASS_DISABLED);
+		return false;
+	}
+
+	now = jiffies;
+	if (unlikely(!batadv_nss_policy_cache_valid(hard_iface, now)))
+		batadv_nss_policy_cache_refresh(hard_iface);
+
+	if (unlikely(!hard_iface->nss_policy_ifname_allowed)) {
+		if (bat_priv)
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_BYPASS_IFNAME);
+		return false;
+	}
+
+	if (unlikely(!hard_iface->nss_policy_hardif_supported)) {
+		if (bat_priv) {
+			if (is_wifi) {
+				batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_BYPASS_WIFI);
+				batadv_inc_counter(bat_priv,
+						   BATADV_CNT_NSS_TX_BYPASS_WIFI_POLICY);
+			} else {
+				batadv_inc_counter(bat_priv,
+						   BATADV_CNT_NSS_TX_BYPASS_IFNAME);
+			}
+		}
+		return false;
+	}
+
+	nssctx = READ_ONCE(hard_iface->nssctx);
+	if (unlikely(!nssctx)) {
+		if (batadv_nss_offload_lazy_init &&
+		    batadv_nss_lazy_retry_allowed(hard_iface))
+			batadv_nss_if_init(hard_iface);
+
+		nssctx = READ_ONCE(hard_iface->nssctx);
+		if (unlikely(!nssctx)) {
+			if (bat_priv) {
+				batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_BYPASS_NOCTX);
+				if (READ_ONCE(hard_iface->nssctx_create_failed))
+					batadv_inc_counter(bat_priv,
+							   BATADV_CNT_NSS_TX_BYPASS_NOCTX_CREATE_FAIL);
+				else
+					batadv_inc_counter(bat_priv,
+							   BATADV_CNT_NSS_TX_BYPASS_NOCTX_INIT);
+			}
+			return false;
+		}
+	}
+
+	if (unlikely(READ_ONCE(hard_iface->nssctx_submit_failed))) {
+		if (!batadv_nss_offload_submit_retry_ms) {
+			WRITE_ONCE(hard_iface->nssctx_submit_failed, false);
+		} else {
+			retry_j = msecs_to_jiffies(batadv_nss_offload_submit_retry_ms);
+			if (!time_is_before_jiffies(hard_iface->nssctx_last_submit_fail_jiffies + retry_j)) {
+				if (bat_priv)
+					batadv_inc_counter(bat_priv,
+							   BATADV_CNT_NSS_TX_BYPASS_SUBMIT_COOLDOWN);
+				return false;
+			}
+			WRITE_ONCE(hard_iface->nssctx_submit_failed, false);
+		}
+	}
+
+	if (unlikely(is_wifi &&
+	    !READ_ONCE(hard_iface->nss_policy_wifi_submit_allowed))) {
+		if (bat_priv) {
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_BYPASS_WIFI);
+			batadv_inc_counter(bat_priv,
+					   BATADV_CNT_NSS_TX_BYPASS_WIFI_SUBMIT);
+		}
+		return false;
+	}
+
+	if (unlikely(!is_unicast_ether_addr(dst_addr) &&
+		     !batadv_nss_offload_allow_mcast)) {
+		if (bat_priv)
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_BYPASS_MCAST);
+		return false;
+	}
+
+	if (is_wifi) {
+		batadv_nss_wifi_classify(skb, &wifi_result);
+		if (!wifi_result.allowed) {
+			if (bat_priv) {
+				batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_BYPASS_WIFI);
+				batadv_inc_counter(bat_priv,
+						   BATADV_CNT_NSS_TX_BYPASS_WIFI_POLICY);
+				if (wifi_result.control_nonuc)
+					batadv_nss_wifi_control_nonuc_seen(bat_priv,
+									   wifi_result.packet_type);
+				batadv_nss_wifi_policy_count(bat_priv, wifi_result.reason,
+							     &wifi_result);
+			}
+			return false;
+		}
+	}
+
+	nonlinear_copy = skb_is_nonlinear(skb);
+	if (unlikely(nonlinear_copy && !batadv_nss_offload_nonlinear_copy)) {
+		if (bat_priv)
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_BYPASS_NONLINEAR);
+		return false;
+	}
+
+	if (unlikely(nonlinear_copy && bat_priv))
+		batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_NONLINEAR_COPY);
+
+	if (bat_priv)
+		batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_ATTEMPT);
+
+	if (likely(direct_submit)) {
+		nssctx = batadv_nss_ctx_get(hard_iface);
+		if (unlikely(!nssctx)) {
+			if (bat_priv)
+				batadv_inc_counter(bat_priv,
+						   BATADV_CNT_NSS_TX_BYPASS_SUBMIT_COOLDOWN);
+			return false;
+		}
+
+		skb->mark |= 0x80000000u;
+		status = nss_virt_if_tx_buf(nssctx, skb);
+		batadv_nss_ctx_put(hard_iface);
+		if (unlikely(status != NSS_TX_SUCCESS)) {
+			WRITE_ONCE(hard_iface->nssctx_submit_failed, true);
+			hard_iface->nssctx_last_submit_fail_jiffies = jiffies;
+			/* Direct-submit path marks skb to avoid immediate reprocessing loops. */
+			skb->mark &= ~0x80000000u;
+			if (bat_priv) {
+				batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_SUBMIT_FAIL);
+				batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_FALLBACK);
+			}
+			return false;
+		}
+
+		WRITE_ONCE(hard_iface->nssctx_submit_failed, false);
+		if (bat_priv)
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_SUCCESS);
+		*ret = NET_XMIT_SUCCESS;
+		return true;
+	}
+
+	nss_skb = nonlinear_copy ? skb_copy(skb, GFP_ATOMIC) :
+		  skb_clone(skb, GFP_ATOMIC);
+	if (!nss_skb) {
+		if (bat_priv) {
+			if (nonlinear_copy)
+				batadv_inc_counter(bat_priv,
+						   BATADV_CNT_NSS_TX_NONLINEAR_COPY_FAIL);
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_CLONE_FAIL);
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_FALLBACK);
+		}
+		return false;
+	}
+
+	if (nonlinear_copy && skb_is_nonlinear(nss_skb) &&
+	    skb_linearize(nss_skb)) {
+		kfree_skb(nss_skb);
+		if (bat_priv) {
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_BYPASS_NONLINEAR);
+			batadv_inc_counter(bat_priv,
+					   BATADV_CNT_NSS_TX_NONLINEAR_LINEARIZE_FAIL);
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_CLONE_FAIL);
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_FALLBACK);
+		}
+		return false;
+	}
+
+	nss_skb->mark |= 0x80000000u;
+	nssctx = batadv_nss_ctx_get(hard_iface);
+	if (unlikely(!nssctx)) {
+		kfree_skb(nss_skb);
+		if (bat_priv)
+			batadv_inc_counter(bat_priv,
+					   BATADV_CNT_NSS_TX_BYPASS_SUBMIT_COOLDOWN);
+		return false;
+	}
+
+	status = nss_virt_if_tx_buf(nssctx, nss_skb);
+	batadv_nss_ctx_put(hard_iface);
+	if (unlikely(status != NSS_TX_SUCCESS)) {
+		kfree_skb(nss_skb);
+		WRITE_ONCE(hard_iface->nssctx_submit_failed, true);
+		hard_iface->nssctx_last_submit_fail_jiffies = jiffies;
+		if (bat_priv) {
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_SUBMIT_FAIL);
+			batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_FALLBACK);
+		}
+		return false;
+	}
+
+	WRITE_ONCE(hard_iface->nssctx_submit_failed, false);
+	if (bat_priv)
+		batadv_inc_counter(bat_priv, BATADV_CNT_NSS_TX_SUCCESS);
+	consume_skb(skb);
+	*ret = NET_XMIT_SUCCESS;
+	return true;
+}
