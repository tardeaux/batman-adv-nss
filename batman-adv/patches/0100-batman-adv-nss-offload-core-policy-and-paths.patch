+bool batadv_nss_ifname_allowed(struct batadv_hard_iface *hard_iface)
+{
+	if (!batadv_nss_offload_ifname[0])
+		return true;
+
+	return batadv_nss_ifname_match(batadv_nss_offload_ifname,
+				       hard_iface->net_dev->name);
+}
+
+bool batadv_nss_hardif_supported(struct batadv_hard_iface *hard_iface)
+{
+	if (!batadv_is_wifi_hardif(hard_iface))
+		return batadv_nss_offload_allow_eth;
+
+	if (!batadv_nss_offload_allow_wifi)
+		return false;
+
+	if (!batadv_nss_offload_wifi_ifname[0])
+		return true;
+
+	return batadv_nss_ifname_match(batadv_nss_offload_wifi_ifname,
+				       hard_iface->net_dev->name);
+}
+
+bool batadv_nss_wifi_submit_allowed(struct batadv_hard_iface *hard_iface)
+{
+	if (!batadv_is_wifi_hardif(hard_iface))
+		return true;
+
+	return batadv_nss_offload_allow_wifi &&
+	       batadv_nss_offload_wifi_submit;
+}
+
+void batadv_nss_policy_cache_refresh(struct batadv_hard_iface *hard_iface)
+{
+	unsigned int cache_ms = batadv_nss_offload_policy_cache_ms;
+	const bool is_wifi = batadv_is_wifi_hardif(hard_iface);
+	unsigned long ttl;
+
+	hard_iface->nss_policy_ifname_allowed = batadv_nss_ifname_allowed(hard_iface);
+	if (is_wifi) {
+		hard_iface->nss_policy_hardif_supported =
+			batadv_nss_offload_allow_wifi &&
+			(!batadv_nss_offload_wifi_ifname[0] ||
+			 batadv_nss_ifname_match(batadv_nss_offload_wifi_ifname,
+						 hard_iface->net_dev->name));
+		hard_iface->nss_policy_wifi_submit_allowed =
+			batadv_nss_offload_allow_wifi &&
+			batadv_nss_offload_wifi_submit;
+	} else {
+		hard_iface->nss_policy_hardif_supported =
+			batadv_nss_offload_allow_eth;
+		hard_iface->nss_policy_wifi_submit_allowed = true;
+	}
+
+	if (!cache_ms)
+		cache_ms = BATADV_NSS_OFFLOAD_POLICY_CACHE_MS_DEFAULT;
+
+	ttl = msecs_to_jiffies(cache_ms);
+	WRITE_ONCE(hard_iface->nss_policy_cache_expires, jiffies + ttl);
+}
+
+bool batadv_nss_lazy_retry_allowed(struct batadv_hard_iface *hard_iface)
+{
+	unsigned long retry_j;
+
+	if (!READ_ONCE(hard_iface->nssctx_create_failed))
+		return true;
+
+	if (!batadv_nss_offload_retry_ms) {
+		WRITE_ONCE(hard_iface->nssctx_create_failed, false);
+		return true;
+	}
+
+	retry_j = msecs_to_jiffies(batadv_nss_offload_retry_ms);
+	if (time_is_before_jiffies(hard_iface->nssctx_last_create_jiffies + retry_j)) {
+		WRITE_ONCE(hard_iface->nssctx_create_failed, false);
+		return true;
+	}
+
+	return false;
+}
+
+static bool batadv_nss_wifi_control_nonuc_packettype(u8 packet_type)
+{
+	switch (packet_type) {
+	case BATADV_IV_OGM:
+	case BATADV_OGM2:
+	case BATADV_ELP:
+	case BATADV_CODED:
+		return true;
+	default:
+		return false;
+	}
+}
+
+static bool batadv_nss_wifi_u4_control_class(u8 subtype)
+{
+	switch (subtype) {
+	case BATADV_P_DAT_DHT_GET:
+	case BATADV_P_DAT_DHT_PUT:
+	case BATADV_P_DAT_CACHE_REPLY:
+		return true;
+	default:
+		return false;
+	}
+}
+
+static bool batadv_nss_wifi_u4_control_subtype(u8 subtype)
+{
+	if (subtype >= sizeof(batadv_nss_offload_wifi_policy_u4_control_mask) * 8)
+		return false;
+
+	return !!(batadv_nss_offload_wifi_policy_u4_control_mask & BIT(subtype));
+}
+
+void batadv_nss_wifi_classify(struct sk_buff *skb,
+			      struct batadv_nss_wifi_policy_result *result)
+{
+	const struct batadv_unicast_packet *unicast_packet;
+	const struct batadv_unicast_4addr_packet *u4_packet;
+	bool u4_control;
+
+	result->allowed = false;
+	result->reason = BATADV_NSS_WIFI_POLICY_NONUNICAST;
+	result->packet_type = 0;
+	result->subtype = 0;
+	result->control_nonuc = false;
+
+	if (unlikely(skb->len < ETH_HLEN + sizeof(*unicast_packet))) {
+		result->reason = BATADV_NSS_WIFI_POLICY_TRUNC;
+		return;
+	}
+
+	unicast_packet = (const struct batadv_unicast_packet *)(skb->data + ETH_HLEN);
+	result->packet_type = unicast_packet->packet_type;
+
+	switch (unicast_packet->packet_type) {
+	case BATADV_UNICAST:
+	case BATADV_UNICAST_FRAG:
+	case BATADV_ICMP:
+	case BATADV_UNICAST_TVLV:
+		result->allowed = true;
+		result->reason = BATADV_NSS_WIFI_POLICY_OK;
+		return;
+	case BATADV_UNICAST_4ADDR:
+		if (unlikely(skb->len < ETH_HLEN + sizeof(*u4_packet))) {
+			result->reason = BATADV_NSS_WIFI_POLICY_TRUNC;
+			return;
+		}
+
+		u4_packet = (const struct batadv_unicast_4addr_packet *)unicast_packet;
+		result->subtype = u4_packet->subtype;
+		u4_control = batadv_nss_wifi_u4_control_class(u4_packet->subtype);
+
+		if (u4_packet->subtype == BATADV_P_DATA) {
+			result->allowed = true;
+			result->reason = BATADV_NSS_WIFI_POLICY_OK;
+			return;
+		}
+
+		if (u4_control &&
+		    batadv_nss_wifi_u4_control_subtype(u4_packet->subtype)) {
+			result->allowed = true;
+			result->reason = BATADV_NSS_WIFI_POLICY_OK;
+			return;
+		}
+
+		result->reason = u4_control ?
+				 BATADV_NSS_WIFI_POLICY_U4_CONTROL :
+				 BATADV_NSS_WIFI_POLICY_U4_NONDATA;
+		return;
+	default:
+		result->control_nonuc =
+			batadv_nss_wifi_control_nonuc_packettype(unicast_packet->packet_type);
+		result->allowed = false;
+		result->reason = BATADV_NSS_WIFI_POLICY_NONUNICAST;
+		return;
+	}
+}
+
+void batadv_nss_wifi_policy_count(struct batadv_priv *bat_priv,
+				  enum batadv_nss_wifi_policy_reason reason,
+				  const struct batadv_nss_wifi_policy_result *result)
+{
+	if (!bat_priv)
+		return;
+
+	switch (reason) {
+	case BATADV_NSS_WIFI_POLICY_TRUNC:
+		batadv_inc_counter(bat_priv,
+				   BATADV_CNT_NSS_TX_BYPASS_WIFI_POLICY_TRUNC);
+		break;
+	case BATADV_NSS_WIFI_POLICY_U4_CONTROL:
+		batadv_inc_counter(bat_priv,
+				   BATADV_CNT_NSS_TX_BYPASS_WIFI_POLICY_U4_CONTROL);
+		break;
+	case BATADV_NSS_WIFI_POLICY_U4_NONDATA:
+		batadv_inc_counter(bat_priv,
+				   BATADV_CNT_NSS_TX_BYPASS_WIFI_POLICY_U4_NONDATA);
+		break;
+	case BATADV_NSS_WIFI_POLICY_NONUNICAST:
+		if (result && result->control_nonuc) {
+			batadv_inc_counter(bat_priv,
+					   BATADV_CNT_NSS_TX_BYPASS_WIFI_POLICY_CONTROL_NONUC);
+			switch (result->packet_type) {
+			case BATADV_IV_OGM:
+				batadv_inc_counter(bat_priv,
+						   BATADV_CNT_NSS_TX_BYPASS_WIFI_POLICY_CONTROL_NONUC_IV_OGM);
+				break;
+			case BATADV_OGM2:
+				batadv_inc_counter(bat_priv,
+						   BATADV_CNT_NSS_TX_BYPASS_WIFI_POLICY_CONTROL_NONUC_OGM2);
+				break;
+			case BATADV_ELP:
+				batadv_inc_counter(bat_priv,
+						   BATADV_CNT_NSS_TX_BYPASS_WIFI_POLICY_CONTROL_NONUC_ELP);
+				break;
+			case BATADV_CODED:
+				batadv_inc_counter(bat_priv,
+						   BATADV_CNT_NSS_TX_BYPASS_WIFI_POLICY_CONTROL_NONUC_CODED);
+				break;
+			}
+		} else {
+			batadv_inc_counter(bat_priv,
+					   BATADV_CNT_NSS_TX_BYPASS_WIFI_POLICY_NONUNICAST);
+		}
+		break;
+	case BATADV_NSS_WIFI_POLICY_OK:
+		break;
+	}
+}
