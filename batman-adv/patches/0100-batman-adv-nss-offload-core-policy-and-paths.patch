+++ b/net/batman-adv/nss.c	2026-03-05 18:37:58.449678145 -0600
@@ -0,0 +1,170 @@
+// SPDX-License-Identifier: GPL-2.0
+/* Copyright (C) B.A.T.M.A.N. contributors:
+ *
+ * Marek Lindner, Simon Wunderlich
+ */
+
+#include "nss.h"
+
+#include <linux/atomic.h>
+#include <linux/delay.h>
+#include <linux/jiffies.h>
+
+#include <nss_api_if.h>
+
+#include "hard-interface.h"
+#include "nss_internal.h"
+
+void batadv_nss_if_init(struct batadv_hard_iface *hard_iface)
+{
+	enum nss_dynamic_interface_type src_if_type;
+	int32_t if_num_h2n;
+	int32_t src_if_num;
+	nss_tx_status_t nh_status;
+	uint32_t nh_if_num;
+	uint32_t nexthop_h2n;
+
+	if (READ_ONCE(hard_iface->nssctx))
+		return;
+
+	if (atomic_cmpxchg(&hard_iface->nssctx_init_in_progress, 0, 1))
+		return;
+
+	if (READ_ONCE(hard_iface->nssctx))
+		goto out_init_unlock;
+
+	if (!batadv_nss_ifname_allowed(hard_iface))
+		goto out_init_unlock;
+
+	if (!batadv_nss_hardif_supported(hard_iface))
+		goto out_init_unlock;
+
+	if (batadv_is_wifi_hardif(hard_iface) &&
+	    !batadv_nss_offload_wifi_create)
+		goto out_init_unlock;
+
+	hard_iface->nssctx_create_failed = false;
+	WRITE_ONCE(hard_iface->nssctx_teardown, false);
+	atomic_set(&hard_iface->nssctx_users, 0);
+	hard_iface->nssctx_dev_held = false;
+	hard_iface->nssctx_last_create_jiffies = jiffies;
+	hard_iface->nssctx_submit_failed = false;
+	hard_iface->nssctx_last_submit_fail_jiffies = 0;
+	hard_iface->nss_policy_cache_expires = 0;
+	hard_iface->nss_policy_ifname_allowed = false;
+	hard_iface->nss_policy_hardif_supported = false;
+	hard_iface->nss_policy_wifi_submit_allowed = false;
+
+	nexthop_h2n = NSS_ETH_RX_INTERFACE;
+	if_num_h2n = nss_cmn_get_interface_number_by_dev(hard_iface->net_dev);
+	if (if_num_h2n >= 0)
+		nexthop_h2n = (uint32_t)if_num_h2n;
+
+	hard_iface->nssctx = nss_virt_if_create_sync_nexthop(hard_iface->net_dev,
+							      NSS_N2H_INTERFACE,
+							      nexthop_h2n);
+	if (hard_iface->nssctx && if_num_h2n < 0)
+		pr_debug("Using NSS_ETH_RX_INTERFACE as h2n nexthop for %s\n",
+			 hard_iface->net_dev->name);
+	if (!hard_iface->nssctx) {
+		hard_iface->nssctx_create_failed = true;
+		pr_warn("Unable to create NSS virtual interface for %s\n",
+			hard_iface->net_dev->name);
+	}
+
+	if (hard_iface->nssctx)
+		nss_virt_if_register(hard_iface->nssctx, batadv_nss_receive_from_nss,
+				     hard_iface->net_dev);
+	if (hard_iface->nssctx)
+		hard_iface->nssctx_dev_held = true;
+
+	if (!hard_iface->nssctx)
+		goto out_init_unlock;
+
+	src_if_num = if_num_h2n;
+	if (src_if_num < 0)
+		goto out_init_unlock;
+
+	/*
+	 * nss_if_set_nexthop() is valid for physical interfaces and VAP dynamic
+	 * interfaces. For wifi mesh dynamic interfaces the firmware rejects this
+	 * message (NSS_TX_FAILURE), so skip programming and keep software path.
+	 */
+	if (nss_is_dynamic_interface((uint32_t)src_if_num)) {
+		src_if_type = nss_dynamic_interface_get_type(hard_iface->nssctx->nss_ctx,
+							    src_if_num);
+		if (src_if_type != NSS_DYNAMIC_INTERFACE_TYPE_VAP)
+			goto out_init_unlock;
+	}
+
+	nh_if_num = hard_iface->nssctx->if_num_n2h;
+	nh_status = nss_if_set_nexthop(hard_iface->nssctx->nss_ctx,
+				       (uint32_t)src_if_num,
+				       nh_if_num);
+	if (nh_status != NSS_TX_SUCCESS)
+		pr_warn("Unable to set NSS nexthop for %s if_num %d -> %u: %d\n",
+			hard_iface->net_dev->name, src_if_num, nh_if_num, nh_status);
+
+out_init_unlock:
+	atomic_set(&hard_iface->nssctx_init_in_progress, 0);
+}
+
+void batadv_nss_if_deinit(struct batadv_hard_iface *hard_iface)
+{
+	struct nss_virt_if_handle *nssctx = hard_iface->nssctx;
+	int32_t src_if_num;
+	nss_tx_status_t status;
+	unsigned int wait_tries = 0;
+
+	nssctx = xchg(&hard_iface->nssctx, NULL);
+
+	if (!nssctx)
+		return;
+	WRITE_ONCE(hard_iface->nssctx_teardown, true);
+	smp_mb();
+
+	hard_iface->nssctx_create_failed = false;
+	hard_iface->nssctx_last_create_jiffies = 0;
+	hard_iface->nssctx_submit_failed = false;
+	hard_iface->nssctx_last_submit_fail_jiffies = 0;
+	hard_iface->nss_policy_cache_expires = 0;
+
+	while (atomic_read(&hard_iface->nssctx_users) > 0 && wait_tries < 5000) {
+		usleep_range(1000, 2000);
+		wait_tries++;
+	}
+	if (atomic_read(&hard_iface->nssctx_users) > 0) {
+		WRITE_ONCE(hard_iface->nssctx, nssctx);
+		WRITE_ONCE(hard_iface->nssctx_teardown, false);
+		pr_warn("Skipping NSS teardown for %s while %d users still in-flight\n",
+			hard_iface->net_dev->name,
+			atomic_read(&hard_iface->nssctx_users));
+		return;
+	}
+
+	src_if_num = nss_cmn_get_interface_number_by_dev(hard_iface->net_dev);
+	if (src_if_num >= 0)
+		nss_if_reset_nexthop(nssctx->nss_ctx, (uint32_t)src_if_num);
+
+	for (wait_tries = 0; wait_tries < 4000; wait_tries++) {
+		status = nss_virt_if_destroy_sync(nssctx);
+		if (status == NSS_TX_SUCCESS)
+			break;
+		usleep_range(2000, 4000);
+	}
+	if (status != NSS_TX_SUCCESS)
+		pr_warn("Unable to destroy NSS virtual interface for %s after %u retries: %d\n",
+			hard_iface->net_dev->name, wait_tries, status);
+
+	if (status == NSS_TX_SUCCESS) {
+		hard_iface->nssctx_dev_held = false;
+	} else if (status == NSS_TX_FAILURE_BAD_PARAM &&
+		   hard_iface->nssctx_dev_held) {
+		dev_put(hard_iface->net_dev);
+		hard_iface->nssctx_dev_held = false;
+		pr_warn("Compensated NSS netdev reference on destroy failure for %s\n",
+			hard_iface->net_dev->name);
+	}
+
+	WRITE_ONCE(hard_iface->nssctx_teardown, false);
+}
