+static bool batadv_nss_ifname_match(const char *ifname_list, const char *ifname)
+{
+	const char *token, *end, *trimmed_end;
+	size_t token_len, ifname_len;
+
+	if (!ifname_list[0])
+		return true;
+
+	ifname_len = strlen(ifname);
+	token = ifname_list;
+
+	while (*token) {
+		while (*token == ',' || *token == ' ' || *token == '\t')
+			token++;
+		if (!*token)
+			break;
+
+		end = token;
+		while (*end && *end != ',')
+			end++;
+
+		trimmed_end = end;
+		while (trimmed_end > token &&
+		       (*(trimmed_end - 1) == ' ' ||
+			*(trimmed_end - 1) == '\t'))
+			trimmed_end--;
+
+		token_len = trimmed_end - token;
+		if (token_len == 1 && token[0] == '*')
+			return true;
+		if (token_len == 3 && !strncmp(token, "any", 3))
+			return true;
+		if (token_len == ifname_len && !strncmp(token, ifname, token_len))
+			return true;
+		if (token_len > 1 && token[token_len - 1] == '*' &&
+		    ifname_len >= token_len - 1 &&
+		    !strncmp(token, ifname, token_len - 1))
+			return true;
+
+		token = end;
+	}
+
+	return false;
+}
